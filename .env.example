# ─── App URL ─────────────────────────────────────────────────────────
# Absolute URL the app serves from. Used to build magic-link redirectTo.
# In dev: http://localhost:3000. In prod: https://sentry.darkrocklabs.com.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Supabase ────────────────────────────────────────────────────────
# Public — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Server-only — bypasses RLS, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Postgres (Supabase) ─────────────────────────────────────────────
# At runtime, point to the Supabase connection-pooler URL (port 6543).
# When running `prisma migrate`, temporarily swap to the direct URL
# (port 5432) — see SUPABASE_SETUP.md.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
SUPABASE_DIRECT_URL="postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ─── Email (non-auth notifications) ──────────────────────────────────
# Optional. If set, src/lib/email.ts uses Resend to send notifications,
# alerts, or any non-auth message. Auth emails (invites, magic links)
# always go through Supabase's configured SMTP.
RESEND_API_KEY=
EMAIL_FROM="Sentry by Dark Rock <noreply@darkrocksecurity.com>"

# ─── Threat Intelligence ─────────────────────────────────────────────
NVD_API_KEY=              # Free: https://nvd.nist.gov/developers/request-an-api-key
THREAT_INTEL_CRON=true    # Enable/disable cron feed polling
CRON_SECRET=              # Optional: protects cron endpoint
